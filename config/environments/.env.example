# ══════════════════════════════════════════════════
# CONDUIT — Environment Variables Template
# ══════════════════════════════════════════════════
# Copy to .env.local for development.
# NEVER commit actual values. (Prompt 0.3 — Secrets Management)

# ── Application ──
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
CORS_ORIGINS=http://localhost:5173

# ── Database (PostgreSQL 15 + pgvector) ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=conduit
POSTGRES_USER=conduit
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── Redis (Cache + Celery Broker + Locks) ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/1

# ── JWT Authentication (RS256) ──
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private_key
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public_key
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI Providers (via LiteLLM) ──
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
GEMINI_API_KEY=CHANGE_ME
OPENAI_API_KEY=sk-CHANGE_ME
LITELLM_MASTER_KEY=CHANGE_ME
DEFAULT_AI_MODEL=claude-sonnet-4-5-20241022

# ── Object Storage (S3 / MinIO) ──
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET_PLANS=conduit-plans
S3_BUCKET_EXPORTS=conduit-exports
S3_BUCKET_PHOTOS=conduit-photos
S3_BUCKET_BACKUPS=conduit-backups
S3_BUCKET_TILES=conduit-tiles

# ── Email (SendGrid / SES) ──
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=CHANGE_ME
EMAIL_FROM=noreply@conduit.build

# ── Push Notifications (FCM) ──
FCM_SERVER_KEY=CHANGE_ME
FCM_PROJECT_ID=conduit-prod

# ── Observability ──
SENTRY_DSN=CHANGE_ME
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
LOKI_URL=http://loki:3100

# ── Backup ──
BACKUP_ENCRYPTION_KEY=CHANGE_ME
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=12

# ── Feature Flags ──
FEATURE_M15_SIMULATION=false
FEATURE_AI_ASSISTANT=true
FEATURE_FIELD_SYNC=true
