# Conduit Backend — .env.example
# Copy to .env and fill in values
# NEVER commit .env to git
#
# VPS: api.climbpeakdigital.com | User: onecpd
# Bliss Systems LLC — APEX Standard

# ── Application ─────────────────────────────────────────
ENVIRONMENT=production
SECRET_KEY=change-me-min-32-chars-random-string

# ── Database ─────────────────────────────────────────────
POSTGRES_DB=conduit
POSTGRES_USER=conduit
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql+asyncpg://conduit:change-me-strong-password@db:5432/conduit

# ── Redis ────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@redis:6379/0

# ── JWT (RSA RS256 — MANDATORY in production) ────────────
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   cat private.pem | base64 | tr -d '\n'  → JWT_PRIVATE_KEY
#   cat public.pem  | base64 | tr -d '\n'  → JWT_PUBLIC_KEY
JWT_PRIVATE_KEY=base64-encoded-rsa-private-key
JWT_PUBLIC_KEY=base64-encoded-rsa-public-key
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Email (SMTP) ─────────────────────────────────────────
# Use mail.climbpeakdigital.com (already on VPS)
SMTP_HOST=mail.climbpeakdigital.com
SMTP_PORT=587
SMTP_USER=noreply@climbpeakdigital.com
SMTP_PASSWORD=change-me-smtp-password
SMTP_FROM=Conduit <noreply@climbpeakdigital.com>

# ── Frontend ─────────────────────────────────────────────
FRONTEND_URL=https://climbpeakdigital.com
ALLOWED_ORIGINS=https://climbpeakdigital.com,https://api.climbpeakdigital.com

# ── Rate Limiting ────────────────────────────────────────
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW=900
GLOBAL_RATE_LIMIT=100
